# Metabase instance base URL (no trailing slash)
METABASE_URL=https://your-metabase.example.com

# Metabase login credentials
METABASE_USER=your@email.com
METABASE_PASSWORD=yourpassword

# Saved-question card IDs (find in the URL when viewing a question: /question/<ID>)
METABASE_CR_CARD_ID=123
METABASE_QUERY_CARD_ID=456

# Optional — only needed when running with --benefit flag
METABASE_BENEFIT_CARD_ID=

# Optional — card ID of a saved question that returns only active policy_no values
# When set, the pipeline will filter dashboard results to active policies only
METABASE_ACTIVE_POLICY_CARD_ID=

# Target Google Drive folder ID for uploads
GOOGLE_DRIVE_FOLDER_ID=

# OAuth 2.0 client secret file (relative to project root, or absolute path)
# Download from Google Cloud Console → APIs & Services → Credentials
# For web-type clients register http://localhost:8080/ as an Authorized redirect URI
GOOGLE_OAUTH_CLIENT_SECRET=satria_yudha.json

# Master tracking spreadsheet (spreadsheet ID from the URL)
MASTER_SPREADSHEET_ID=1s7WeJG40XEAa-WuIrxuyuukAiIliXHjtwFiKqWDC-TA

# Sheet tab name inside the master spreadsheet (e.g. FINAL, 2026)
MASTER_SHEET_NAME=FINAL

# Optional — pre-fills the Google account chooser on first OAuth consent.
# Useful when you have multiple Google accounts in your browser.
GOOGLE_LOGIN_HINT=you@example.com
